NOPECHA_API_KEY=your_key_here

# Your Minecraft username
NICK=YourNickHere

# Set to true to show browser window on your real display (for debugging)
DEBUG=false

# How long to wait for NopeCHA to solve a captcha, in milliseconds
CAPTCHA_TIMEOUT_MS=30000

# Timeout for HTTP requests (vote eligibility check phase), in seconds
HTTP_TIMEOUT_S=15
